{% assign id = trmnl.plugin_settings.custom_fields_values.item_id %}
<div class="layout layout--col gap--space-between">
  <div class="grid grid--cols-2">
    <div class="item item--center border--0">
      <div class="meta"></div> <div class="content">
        <img class="image" src="{{ IDX_0.item.icon_large }}" style="height: 80px; width: auto;">
      </div>
    </div>

    <div class="item border--0">
      <div class="meta"></div>
      <div class="content layout--col justify--center">
        <div class="layout--row align--center gap--1">
          <span class="label lg:label--large">High</span>
          <span class="value value--xsmall lg:value--small lg:portrait:value--base value--tnums">{{ IDX_1.data[id].high | number_with_delimiter }}</span>
        </div>
        
        <div class="separator separator--dotted my--1"></div>

        <div class="layout--row align--center gap--1">
          <span class="label lg:label--large"">Low</span>
          <span class="value value--xsmall lg:value--small lg:portrait:value--base value--tnums">{{ IDX_1.data[id].low | number_with_delimiter }}</span>
        </div>
      </div>
    </div>
  </div>

  <div class="border--h-1 w--full"></div>

  <div class="grid">
    <div class="row">
      <div class="grid">
        <div class="item col--span-1 border--0">
          <div class="meta"></div>
          <div class="content">
            <span class="value value--xsmall lg:value--small lg:portrait:value--base">{{ IDX_0.item.day30.change }}</span>
            <span class="label lg:label--large">30D</span>
          </div>
        </div>

        <div class="item col--span-1 border--0">
          <div class="meta"></div>
          <div class="content">
            <span class="value value--xsmall lg:value--small lg:portrait:value--base">{{ IDX_0.item.day90.change }}</span>
            <span class="label lg:label--large">90D</span>
          </div>
        </div>

        <div class="item col--span-1 border--0">
          <div class="meta"></div>
          <div class="content">
            <span class="value value--xsmall lg:value--small lg:portrait:value--base">{{ IDX_0.item.day180.change }}</span>
            <span class="label lg:label--large">180D</span>
          </div>
        </div>

        <div class="item col--span-1 border--0">
          <div class="meta"></div>
          <div class="content">
            <span class="value value--xsmall lg:value--small lg:portrait:value--base">{{ IDX_0.item.today.price }}</span>
            <span class="label lg:label--large">Price</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="title_bar">
  <img class="image" src="{{ IDX_0.item.icon }}">
  <span class="title">GE: {{ IDX_0.item.name }}</span>
</div>
